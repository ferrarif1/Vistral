VITE_APP_NAME=Vistral
VITE_DEFAULT_LLM_BASE_URL=https://api.chatanywhere.tech/v1
VITE_DEFAULT_LLM_MODEL=gpt-3.5-turbo
API_PORT=8787
API_HOST=127.0.0.1
# Docker-first default (mirror-friendly). Override to Docker Hub if needed.
# NODE_BASE_IMAGE=node:20-alpine
# NGINX_BASE_IMAGE=nginx:1.27-alpine
NODE_BASE_IMAGE=docker.m.daocloud.io/library/node:20-alpine
NGINX_BASE_IMAGE=docker.m.daocloud.io/library/nginx:1.27-alpine
VISTRAL_API_IMAGE=vistral-api:round1
VISTRAL_WEB_IMAGE=vistral-web:round1
LLM_CONFIG_SECRET=replace-with-strong-secret
DEFAULT_USER_ID=u-1
DEFAULT_USER_PASSWORD=mock-pass
DEFAULT_ADMIN_PASSWORD=mock-pass-admin
PADDLEOCR_RUNTIME_ENDPOINT=
PADDLEOCR_RUNTIME_API_KEY=
PADDLEOCR_LOCAL_TRAIN_COMMAND=
PADDLEOCR_LOCAL_PREDICT_COMMAND=
DOCTR_RUNTIME_ENDPOINT=
DOCTR_RUNTIME_API_KEY=
DOCTR_LOCAL_TRAIN_COMMAND=
DOCTR_LOCAL_PREDICT_COMMAND=
YOLO_RUNTIME_ENDPOINT=
YOLO_RUNTIME_API_KEY=
YOLO_LOCAL_TRAIN_COMMAND=
YOLO_LOCAL_PREDICT_COMMAND=
# Optional one-click runtime profiles (JSON array). Example:
# VISTRAL_RUNTIME_PROFILES_JSON=[{"id":"prod-realtime","label":"Prod realtime","description":"Use managed runtime cluster","frameworks":{"paddleocr":{"endpoint":"https://ocr.example.com/predict","api_key":"${OCR_KEY}"},"doctr":{"endpoint":"https://doctr.example.com/predict","api_key":"${DOCTR_KEY}"},"yolo":{"endpoint":"https://yolo.example.com/predict","api_key":"${YOLO_KEY}"}},"controls":{"python_bin":"/opt/vistral/.venv/bin/python","disable_simulated_train_fallback":true,"disable_inference_fallback":true}}]
VISTRAL_RUNTIME_PROFILES_JSON=
LOCAL_RUNNER_TIMEOUT_MS=1800000
VISTRAL_RUNNER_ENABLE_REAL=0
# Default strict: block model-version registration for local_command jobs whose artifact summary
# indicates template/fallback/non-real execution evidence.
# Set to 1 only for explicit non-production compatibility.
MODEL_VERSION_REGISTER_ALLOW_NON_REAL_LOCAL_COMMAND=0
VISTRAL_YOLO_MODEL_PATH=
VISTRAL_PADDLEOCR_LANG=ch
VISTRAL_PADDLEOCR_USE_GPU=0
VISTRAL_DOCTR_DET_ARCH=db_resnet50
VISTRAL_DOCTR_RECO_ARCH=crnn_vgg16_bn
TRAINING_WORKER_SHARED_TOKEN=
TRAINING_WORKER_HEARTBEAT_TTL_MS=45000
TRAINING_WORKER_DISPATCH_TIMEOUT_MS=1800000
TRAINING_WORKER_DISPATCH_FALLBACK_LOCAL=1
TRAINING_WORKER_DISPATCH_MAX_ATTEMPTS=4
TRAINING_WORKER_DISPATCH_RETRY_BASE_MS=350
TRAINING_WORKER_FAILURE_PENALTY_WINDOW_MS=900000
TRAINING_WORKER_FAILURE_COOLDOWN_MS=120000
TRAINING_WORKER_FAILURE_PENALTY_STEP=0.18
TRAINING_WORKER_FAILURE_PENALTY_CAP=1.2
TRAINING_WORKER_INLINE_PACKAGE_MAX_FILES=800
TRAINING_WORKER_INLINE_PACKAGE_MAX_BYTES=41943040
TRAINING_WORKER_DISPATCH_BASE_URL=
TRAINING_WORKER_PACKAGE_STORAGE_ROOT=.data/worker-dispatch-packages
TRAINING_WORKER_PACKAGE_TTL_MS=3600000
TRAINING_WORKER_REFERENCE_PACKAGE_MAX_FILES=8000
TRAINING_WORKER_REFERENCE_PACKAGE_MAX_BYTES=536870912
# Example local command templates:
# YOLO_LOCAL_TRAIN_COMMAND=python3 {{repo_root}}/scripts/local-runners/yolo_train_runner.py --job-id {{job_id}} --dataset-id {{dataset_id}} --task-type {{task_type}} --base-model {{base_model}} --workspace-dir {{workspace_dir}} --config-path {{config_path}} --summary-path {{summary_path}} --metrics-path {{metrics_path}} --artifact-path {{artifact_path}}
# PADDLEOCR_LOCAL_TRAIN_COMMAND=python3 {{repo_root}}/scripts/local-runners/paddleocr_train_runner.py --job-id {{job_id}} --dataset-id {{dataset_id}} --task-type {{task_type}} --base-model {{base_model}} --workspace-dir {{workspace_dir}} --config-path {{config_path}} --summary-path {{summary_path}} --metrics-path {{metrics_path}} --artifact-path {{artifact_path}}
# DOCTR_LOCAL_TRAIN_COMMAND=python3 {{repo_root}}/scripts/local-runners/doctr_train_runner.py --job-id {{job_id}} --dataset-id {{dataset_id}} --task-type {{task_type}} --base-model {{base_model}} --workspace-dir {{workspace_dir}} --config-path {{config_path}} --summary-path {{summary_path}} --metrics-path {{metrics_path}} --artifact-path {{artifact_path}}
# YOLO_LOCAL_PREDICT_COMMAND=python3 {{repo_root}}/scripts/local-runners/yolo_predict_runner.py --model-id {{model_id}} --model-version-id {{model_version_id}} --task-type {{task_type}} --input-path {{input_path}} --filename {{filename}} --output-path {{output_path}}
# PADDLEOCR_LOCAL_PREDICT_COMMAND=python3 {{repo_root}}/scripts/local-runners/paddleocr_predict_runner.py --model-id {{model_id}} --model-version-id {{model_version_id}} --task-type {{task_type}} --input-path {{input_path}} --filename {{filename}} --output-path {{output_path}}
# DOCTR_LOCAL_PREDICT_COMMAND=python3 {{repo_root}}/scripts/local-runners/doctr_predict_runner.py --model-id {{model_id}} --model-version-id {{model_version_id}} --task-type {{task_type}} --input-path {{input_path}} --filename {{filename}} --output-path {{output_path}}
# Optional real runner branch (when dependencies are installed):
# VISTRAL_RUNNER_ENABLE_REAL=1
# VISTRAL_YOLO_MODEL_PATH=/opt/models/yolo11n.pt
UPLOAD_STORAGE_ROOT=.data/uploads
TRAINING_WORKDIR_ROOT=.data/training-jobs
APP_STATE_STORE_PATH=.data/app-state.json
APP_STATE_PERSIST_INTERVAL_MS=1200
APP_STATE_BOOTSTRAP_MODE=minimal
RESET_FOUNDATION_PURGE_STORAGE=1
VERIFICATION_REPORTS_DIR=.data/verify-reports
TRAINING_METRICS_MAX_POINTS_PER_JOB=180
TRAINING_METRICS_MAX_TOTAL_ROWS=20000
