# Required: control-plane API base URL (machine A)
CONTROL_PLANE_BASE_URL=http://127.0.0.1:8080

# Preferred: dedicated per-worker token issued by bootstrap pairing
TRAINING_WORKER_AUTH_TOKEN=replace-with-issued-worker-token

# Optional legacy fallback: keep empty unless your control plane still uses shared worker auth
TRAINING_WORKER_SHARED_TOKEN=

# Required: stable unique worker id
WORKER_ID=tw-local-1

# Optional: display name in admin worker registry
WORKER_NAME=training-worker-local-1

# Optional: endpoint that represents this worker node
# For remote worker nodes, do not keep 127.0.0.1 here; set the worker machine IP/domain reachable by control plane.
WORKER_ENDPOINT=http://127.0.0.1:9090

# Optional: online | offline | draining
WORKER_STATUS=online

# Optional: true | false
WORKER_ENABLED=true

# Optional: scheduler capacity hint
WORKER_MAX_CONCURRENCY=1

# Optional: comma-separated capabilities
# Examples:
#   framework:yolo,task:detection
#   framework:paddleocr,task:ocr
WORKER_CAPABILITIES=framework:yolo,task:detection

# Optional: seconds between heartbeat requests
HEARTBEAT_INTERVAL_SECONDS=15

# Optional: set fixed load value [0, +inf). If empty, script auto-detects from system load.
WORKER_REPORTED_LOAD=

# Optional install script controls
WORKER_VENV_DIR=.venv-worker
WORKER_RUNTIME_PROFILE=base

# Worker API server
WORKER_BIND_HOST=0.0.0.0
WORKER_BIND_PORT=9090
WORKER_RUN_DOCTOR_ON_START=true
WORKER_REPO_ROOT=
WORKER_RUN_ROOT=
WORKER_LOCAL_RUN_TIMEOUT_MS=1800000
WORKER_USE_REQUEST_PATHS=false
WORKER_PACKAGE_DOWNLOAD_TIMEOUT_SECONDS=30

# worker command execution policy: fallback | strict
WORKER_COMMAND_FAILURE_MODE=fallback

# set true to skip local command and always use deterministic fallback
WORKER_DISABLE_COMMAND=false

# optional command template overrides
WORKER_LOCAL_TRAIN_COMMAND=
WORKER_YOLO_TRAIN_COMMAND=
WORKER_PADDLEOCR_TRAIN_COMMAND=
WORKER_DOCTR_TRAIN_COMMAND=
