{
  "name": "vistral",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite --host 127.0.0.1 --port 5173",
    "dev:api": "tsx backend/src/server.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "smoke:phase2": "bash scripts/smoke-phase2.sh",
    "smoke:admin:verification-reports": "bash scripts/smoke-admin-verification-reports.sh",
    "smoke:runtime-success": "bash scripts/smoke-runtime-success.sh",
    "smoke:demo:train-data": "bash scripts/smoke-demo-train-data.sh",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f --tail=120",
    "docker:up:registry": "docker compose -f docker-compose.registry.yml up -d",
    "docker:down:registry": "docker compose -f docker-compose.registry.yml down",
    "docker:config:registry": "docker compose -f docker-compose.registry.yml config",
    "docker:images:build": "bash scripts/docker-build-images.sh",
    "docker:images:build-push": "PUSH_IMAGES=true bash scripts/docker-build-images.sh",
    "docker:images:save": "bash scripts/docker-save-images.sh",
    "docker:images:load-up": "bash scripts/docker-load-and-up.sh",
    "docker:healthcheck": "bash scripts/docker-healthcheck.sh",
    "docker:verify:full": "bash scripts/docker-verify-full.sh",
    "docker:release:bundle": "bash scripts/docker-release-bundle.sh",
    "docker:release:bundle:verified": "RUN_VERIFY_FULL=true bash scripts/docker-release-bundle.sh"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/node": "^22.15.17",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.2.0",
    "eslint": "^9.25.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^5.4.19"
  }
}
