{
  "name": "vistral",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite --host 127.0.0.1 --port 5173",
    "dev:api": "tsx backend/src/server.ts",
    "build:api": "tsc -p tsconfig.api.json && node --input-type=module -e \"import { mkdirSync, writeFileSync } from 'node:fs'; mkdirSync('build/api', { recursive: true }); writeFileSync('build/api/package.json', '{\\n  \\\"type\\\": \\\"commonjs\\\"\\n}\\n');\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "doctor:real-training-readiness": "bash scripts/doctor-real-training-readiness.sh",
    "setup:real-training-env": "bash scripts/setup-real-training-env.sh",
    "setup:doctr-preseed": "bash scripts/setup-doctr-preseed.sh",
    "data:prune-prototype": "node scripts/prune-prototype-data.mjs",
    "data:cleanup-test": "bash scripts/cleanup-test-data.sh",
    "data:reset:foundation": "node scripts/reset-app-state-foundation.mjs",
    "smoke:foundation-reset": "bash scripts/smoke-foundation-reset.sh",
    "smoke:adapter-no-placeholder": "tsx scripts/smoke-adapter-no-placeholder.ts",
    "smoke:training-template-guard": "bash scripts/smoke-training-template-guard.sh",
    "smoke:model-version-register-gate": "tsx scripts/smoke-model-version-register-gate.ts",
    "smoke:phase2": "bash scripts/smoke-phase2.sh",
    "smoke:real-closure": "bash scripts/smoke-real-closure.sh",
    "smoke:restart-resume": "bash scripts/smoke-restart-resume.sh",
    "smoke:local-command": "bash scripts/smoke-local-command.sh",
    "smoke:execution-fields": "bash scripts/smoke-execution-fields.sh",
    "smoke:runner-real-fallback": "bash scripts/smoke-runner-real-fallback.sh",
    "smoke:runner-real-upload": "bash scripts/smoke-runner-real-upload.sh",
    "smoke:runner-real-positive": "bash scripts/smoke-runner-real-positive.sh",
    "smoke:runtime-metrics-retention": "bash scripts/smoke-runtime-metrics-retention.sh",
    "smoke:training-metrics-export": "bash scripts/smoke-training-metrics-export.sh",
    "smoke:training-metrics-export-csv": "bash scripts/smoke-training-metrics-export-csv.sh",
    "smoke:admin:verification-retention": "bash scripts/smoke-admin-verification-retention.sh",
    "smoke:verify-report-retention-e2e": "bash scripts/smoke-verify-report-retention-e2e.sh",
    "smoke:attachments": "bash scripts/smoke-attachments.sh",
    "smoke:auth-session": "bash scripts/smoke-auth-session.sh",
    "smoke:account-governance": "bash scripts/smoke-account-governance.sh",
    "smoke:conversation-context": "bash scripts/smoke-conversation-context.sh",
    "smoke:conversation-actions": "bash scripts/smoke-conversation-actions.sh",
    "smoke:conversation-ops-bridge": "bash scripts/smoke-conversation-ops-bridge.sh",
    "smoke:runtime-profile-activation": "bash scripts/smoke-runtime-profile-activation.sh",
    "smoke:inference-feedback-guard": "bash scripts/smoke-inference-feedback-guard.sh",
    "smoke:no-seed-hardcoding": "bash scripts/smoke-no-seed-hardcoding.sh",
    "smoke:core-closure": "bash scripts/smoke-core-closure.sh",
    "smoke:llm-settings": "bash scripts/smoke-llm-settings.sh",
    "smoke:i18n-key-hygiene": "bash scripts/smoke-i18n-key-hygiene.sh",
    "smoke:runtime-settings-persistence": "bash scripts/smoke-runtime-settings-persistence.sh",
    "smoke:admin:verification-reports": "bash scripts/smoke-admin-verification-reports.sh",
    "smoke:runtime-success": "bash scripts/smoke-runtime-success.sh",
    "smoke:ocr-fallback-guard": "bash scripts/smoke-ocr-fallback-guard.sh",
    "smoke:demo:train-data": "bash scripts/smoke-demo-train-data.sh",
    "smoke:ocr-closure": "bash scripts/smoke-ocr-closure.sh",
    "smoke:dataset-export-roundtrip": "bash scripts/smoke-dataset-export-roundtrip.sh",
    "smoke:training-worker-scheduler": "bash scripts/smoke-training-worker-scheduler.sh",
    "smoke:training-worker-dispatch": "bash scripts/smoke-training-worker-dispatch.sh",
    "smoke:training-worker-cancel": "bash scripts/smoke-training-worker-cancel.sh",
    "smoke:training-worker-failover": "bash scripts/smoke-training-worker-failover.sh",
    "smoke:training-worker-health-penalty": "bash scripts/smoke-training-worker-health-penalty.sh",
    "smoke:training-worker-package-reference": "bash scripts/smoke-training-worker-package-reference.sh",
    "smoke:training-worker-dedicated-auth": "bash scripts/smoke-training-worker-dedicated-auth.sh",
    "docker:up": "bash scripts/docker-up.sh",
    "docker:refresh": "bash scripts/docker-up.sh",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f --tail=120",
    "docker:healthcheck": "bash scripts/docker-healthcheck.sh",
    "docker:verify:full": "bash scripts/docker-verify-full.sh"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/node": "^22.15.17",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.2.0",
    "eslint": "^9.25.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^5.4.19"
  }
}
